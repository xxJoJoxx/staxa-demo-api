{
  "name": "staxa-demo-api",
  "version": "1.0.0",
  "description": "Demo task management API for Staxa platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node src/seed.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__tests__/setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/seed.js"
    ]
  }
}
